# =========================================================================
# AI Investment Research Agent - Environment Variables Template
# Copy this file to .env.local and fill in your keys.
# Do NOT check .env.local into source control!
# =========================================================================

# 1. Groq API Configuration (Mandatory)
# Get a key from Groq Console: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# 2. Web Search API Configuration (Choose at least one)
# Tavily API Key (Highly Recommended): Get a key at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI Key (Alternative): Get a key at https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_api_key_here

# Optional configuration
# NEXT_PUBLIC_APP_URL=http://localhost:3000
